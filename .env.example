# Sencho Configuration
# Copy this file to .env and update the values for production

# JWT secret - generate a secure random string for production
JWT_SECRET=your-secure-jwt-secret-here

# Directory containing docker-compose files
COMPOSE_DIR=/path/to/your/compose/files

# Lemon Squeezy (optional — required for in-app checkout and webhook support)
# Get your API key from https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# Lemon Squeezy variant IDs (from your product dashboard)
LEMONSQUEEZY_VARIANT_ID_PERSONAL_MONTHLY=
LEMONSQUEEZY_VARIANT_ID_PERSONAL_ANNUAL=
LEMONSQUEEZY_VARIANT_ID_PERSONAL_LIFETIME=
LEMONSQUEEZY_VARIANT_ID_TEAM_MONTHLY=
LEMONSQUEEZY_VARIANT_ID_TEAM_ANNUAL=
LEMONSQUEEZY_VARIANT_ID_TEAM_LIFETIME=
